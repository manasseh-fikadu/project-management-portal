{
  "name": "project-management-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mail:start": "mailpit --smtp [::]:1025 --listen [::]:8026",
    "mail:start:bg": "sh -c 'mailpit --smtp [::]:1025 --listen [::]:8026 > .mailpit.log 2>&1 & echo $! > .mailpit.pid && echo \"Mailpit started on SMTP 1025 / UI 8026\"'",
    "mail:stop": "sh -c 'if [ -f .mailpit.pid ]; then kill \"$(cat .mailpit.pid)\" 2>/dev/null || true; rm -f .mailpit.pid; else pkill -f \"mailpit\" || true; fi'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "i18next": "^25.8.13",
    "jose": "^6.1.3",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^16.5.4",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wrangler": "^4.65.0"
  }
}
